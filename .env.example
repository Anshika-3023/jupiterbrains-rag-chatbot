# ── Required ───────────────────────────────────────────────────────────────────
# Get your free Groq API key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Optional (defaults shown) ─────────────────────────────────────────────────
# Available Groq models:
#   llama-3.3-70b-versatile   ← recommended (default)
#   llama-3.1-8b-instant      ← fastest / lowest latency
#   mixtral-8x7b-32768        ← long-context tasks
#   gemma2-9b-it              ← lightweight
GROQ_MODEL=llama-3.3-70b-versatile

EMBEDDING_MODEL=all-MiniLM-L6-v2
CHROMA_COLLECTION=jupiterbrains_docs

CHUNK_SIZE=500
CHUNK_OVERLAP=80
TOP_K=4

LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2

# CORS — controls which frontend origins can call the API.
# Use * for local dev only.
# For production / Framer integration, set your exact site URL:
#   ALLOWED_ORIGINS=https://yoursite.framer.app,https://yourdomain.com
ALLOWED_ORIGINS=*
